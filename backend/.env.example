# Copy this to .env for local development
# NEVER commit .env to git

# DynamoDB Local endpoint (leave empty for AWS)
DYNAMODB_ENDPOINT_URL=http://localhost:8001

# Table names
USERS_TABLE=otsentinel-prod-users
DEVICES_TABLE=otsentinel-prod-devices
INCIDENTS_TABLE=otsentinel-prod-incidents
AUDIT_TABLE=otsentinel-prod-audit

# JWT configuration
JWT_SECRET=dev-secret-change-in-prod
JWT_EXPIRE_MINUTES=480

# AWS region
AWS_REGION_NAME=ap-northeast-1

# Optional: Claude AI integration
# ANTHROPIC_API_KEY=your-api-key-here
